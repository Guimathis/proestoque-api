// Em DEV usa SQLite. O script "npm run build" detecta a DATABASE_URL
// e troca automaticamente para "postgresql" quando necessário.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js" // Gera o @prisma/client com tipos TypeScript
}

// ── CATEGORIA ────────────────────────────────────────────────
model Categoria {
  id        String     @id @default(cuid()) // ID único gerado automaticamente
  nome      String
  icone     String
  cor       String
  criadoEm  DateTime   @default(now())

  // Relação: uma Categoria tem muitos Produtos
  produtos  Produto[]

  // Nome da tabela no banco (opcional, por padrão usa o nome do model)
  @@map("categorias")
}

// ── PRODUTO ──────────────────────────────────────────────────
model Produto {
  id                  String    @id @default(cuid())
  nome                String
  quantidade          Int       @default(0)
  quantidadeMinima    Int       @default(0)
  preco               Float
  unidade             String    @default("un")  // "un", "kg", "cx", "L"
  observacao          String?   // O ? significa nullable (opcional)
  foto                String?
  ultimaMovimentacao  DateTime  @default(now())
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt  // Atualizado automaticamente

  // Chave estrangeira → ID da categoria
  categoriaId         String
  // Relação: cada Produto pertence a UMA Categoria
  categoria           Categoria @relation(fields: [categoriaId], references: [id])

  @@map("produtos")
}

// ── USUÁRIO (será expandido na próxima aula com hash de senha) ──
model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique // @unique gera index e garante unicidade
  senha     String   // Sempre guardar hash, nunca a senha em texto!
  refreshToken String?
  criadoEm DateTime @default(now())

  @@map("usuarios")
}

// ──────────────────────────────────────────────────────────────
// NOTAS SOBRE OS TIPOS (PostgreSQL):
// String     → VARCHAR / TEXT no PostgreSQL
// Int        → INTEGER
// Float      → DOUBLE PRECISION
// Boolean    → BOOLEAN
// DateTime   → TIMESTAMP no PostgreSQL
// String?    → nullable (pode ser NULL)
// @id        → chave primária
// @default() → valor padrão
// @unique    → constraint de unicidade
// @updatedAt → atualizado automático pelo Prisma
// @relation  → define a FK e a relação ORM
// @@map      → nome da tabela no banco