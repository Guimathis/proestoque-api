# ── Banco de dados ────────────────────────────────────────────
# DEV → SQLite (arquivo local, sem instalar nada)
DATABASE_URL="file:./dev.db"

# PRODUÇÃO (Railway) → usar a URL fornecida pelo PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:port/database?schema=public"
# O script prebuild.js detecta automaticamente pelo prefixo da URL.

# ── Servidor ──────────────────────────────────────────────────
PORT=3333
NODE_ENV="development"

# ── JWT ───────────────────────────────────────────────────────
# Em produção, use valores fortes e únicos!
JWT_SECRET="sua_chave_secreta_jwt"
JWT_EXPIRES_IN="7d"

JWT_REFRESH_SECRET="sua_chave_secreta_refresh"
JWT_REFRESH_EXPIRES_IN="30d"
